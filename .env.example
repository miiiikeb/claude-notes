# App identity
APP_NAME=Notes

# Auth
ADMIN_EMAIL=miiiikeb@gmail.com
ALLOWED_EMAILS=you@example.com
SESSION_SECRET=                  # generate: python3 -c "import secrets; print(secrets.token_hex(32))"

# SMTP — if unset, OTP codes log to server console (local dev mode)
SMTP_HOST=smtp.migadu.com
SMTP_PORT=465
SMTP_USER=noreply@onemorepeppy.com
SMTP_PASSWORD=

# GitHub Issues integration (admin todo list)
GITHUB_TOKEN=
GH_REPO=miiiikeb/claude-notes

# Docker (must match APP_NAME in deploy.config.sh)
COMPOSE_PROJECT_NAME=notes
