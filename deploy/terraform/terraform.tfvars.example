app_display_name     = "My App"         # shown in login emails

admin_email          = "miiiikeb@gmail.com"
allowed_emails       = "you@example.com,other@example.com"
session_secret       = "generate-with: python3 -c \"import secrets; print(secrets.token_hex(32))\""

smtp_host            = "smtp.migadu.com"
smtp_port            = 465
smtp_user            = "noreply@onemorepeppy.com"
smtp_password        = "your-smtp-password"

github_token         = "ghp_..."
gh_repo              = "miiiikeb/myapp"
